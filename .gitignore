# Update .gitignore
@'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
env/
.venv/

# Environment variables
.env
.env.local
.env.*.local
!.env.example

# Database
*.db
*.sqlite3
data/  # Local development data

# Docker
.dockerignore
docker-compose.override.yml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
'@ | Set-Content -Path .gitignore -Encoding UTF8

Write-Host "✅ Updated .gitignore" -ForegroundColor Green